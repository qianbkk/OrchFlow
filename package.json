{
  "name": "orchflow",
  "version": "0.1.0",
  "description": "OrchFlow - AI 编码 Agent 编排桌面应用（Claude Code / Codex / Copilot CLI 统一面板）",
  "main": "out/main/index.js",
  "author": "qianbkk",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "electron-vite build && electron-builder --win",
    "build:unpack": "electron-vite build && electron-builder --dir",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^5.5.0",
    "keytar": "^7.9.0",
    "lucide-react": "^0.469.0",
    "simple-git": "^3.36.0",
    "zustand": "^5.0.14"
  },
  "optionalDependencies": {
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@lydell/node-pty-win32-x64": "^1.2.0-beta.12"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.168",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@github/copilot": "^1.0.60",
    "@openai/codex": "^0.137.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "electron-vite": "^5.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.5",
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^26.0.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/jest-dom": "^6.9.0"
  }
}
